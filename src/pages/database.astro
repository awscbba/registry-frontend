---
import Layout from '../layouts/Layout.astro';
import LazyDatabasePerformancePanel from '../components/lazy/LazyDatabasePerformancePanel';
import LazyQueryOptimizationPanel from '../components/lazy/LazyQueryOptimizationPanel';
import LazyConnectionPoolMonitor from '../components/lazy/LazyConnectionPoolMonitor';
import LazyDatabaseCharts from '../components/lazy/LazyDatabaseCharts';
---

<Layout title="Database Optimization - AWS User Group Cochabamba">
	<div class="min-h-screen bg-gray-50">
		<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
			<div class="px-4 py-6 sm:px-0">
				<div class="space-y-6">
					<!-- Page Header -->
					<div class="bg-white shadow rounded-lg p-6">
						<h1 class="text-2xl font-bold text-gray-900 mb-2">Database Optimization Dashboard</h1>
						<p class="text-gray-600">Monitor and optimize database performance with real-time metrics, query analysis, and connection pool management.</p>
					</div>

					<!-- Database Performance Panel -->
					<LazyDatabasePerformancePanel client:load showDetailedMetrics={true} />

					<!-- Database Charts -->
					<LazyDatabaseCharts client:load timeRange="24h" metrics={['queryTime', 'poolUtilization', 'throughput', 'connections']} />

					<!-- Query Optimization Panel -->
					<LazyQueryOptimizationPanel client:load showRecommendations={true} allowOptimizationApplication={true} />

					<!-- Connection Pool Monitor -->
					<LazyConnectionPoolMonitor client:load showAllPools={true} alertThreshold={0.8} />
				</div>
			</div>
		</div>
	</div>
</Layout>
